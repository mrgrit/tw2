# tubewar — 환경 변수 예시
# cp .env.example .env  후 값 채우기

# ── API ─────────────────────────────────────────
TUBEWAR_API_HOST=0.0.0.0
TUBEWAR_API_PORT=9200
TUBEWAR_API_KEY=tubewar-api-key-2026
TUBEWAR_JWT_SECRET=change-me-please-make-it-32-chars-or-more
TUBEWAR_JWT_EXPIRES_HOURS=12

# ── DB ──────────────────────────────────────────
# docker compose 가 띄우는 postgres:5435 와 동일
DATABASE_URL=postgresql+asyncpg://tubewar:tubewar@127.0.0.1:5435/tubewar

# ── 6v6 인프라 기본값 (학생이 register 시 override) ──
SIX_DEFAULT_SSH_USER=ccc
SIX_DEFAULT_SSH_PASS=ccc
SIX_DEFAULT_BASTION_KEY=ccc-api-key-2026

# ── 미션 IP 치환 폴백 기준 (학생 인프라 미등록 시) ──
# 미션 지시문은 {{TARGET_IP}}/{{WEB_ENTRY}}/{{ATTACKER_IP}} 플레이스홀더로 저장되고,
# 등록 인프라가 있으면 그 IP로, 없으면 아래 기준값으로 치환된다. 배포마다 수정 가능.
TUBEWAR_REF_TARGET_IP=192.168.0.151
TUBEWAR_REF_WEB_ENTRY=192.168.0.161
TUBEWAR_REF_ATTACKER_IP=192.168.0.202

# ── LLM (Phase 3+) ──────────────────────────────
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=gemma3:4b

# ── Admin bootstrap (최초 기동 시 1회) ──────────
ADMIN_EMAIL=admin@tubewar.app
ADMIN_PASSWORD=change-me-on-first-login
ADMIN_NAME=admin

# ── Google 로그인 (선택) ─────────────────────────
# Google Cloud Console > APIs & Services > Credentials 에서 "OAuth 2.0 Client ID"(웹)를
# 만들고, 승인된 JavaScript 원본에 UI 주소(예: http://localhost:5173)를 등록한 뒤 그
# Client ID 를 아래에 넣으면 로그인 화면에 구글 버튼이 뜬다. 비우면 비활성.
GOOGLE_CLIENT_ID=
# 허용 도메인(예: ync.ac.kr). 비우면 모든 구글 계정 허용.
GOOGLE_ALLOWED_DOMAIN=
# 첫 구글 로그인 시 학생 계정 자동 생성(1) / 사전 등록된 계정만 허용(0).
GOOGLE_AUTO_PROVISION=1
